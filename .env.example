APP_NAME="Padel Booking"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://padel.ngodingyuk.site

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=padel
DB_USERNAME=padel
DB_PASSWORD=

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@ngodingyuk.site"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=padel.ngodingyuk.site,localhost
SESSION_DOMAIN=.ngodingyuk.site

# Dummy payment gateway
PAYMENT_GATEWAY=DummyPaymentGateway
